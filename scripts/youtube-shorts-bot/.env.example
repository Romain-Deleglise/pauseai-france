# ─── Bot YouTube Shorts Pause IA — configuration ──────────────────────
# Copier ce fichier en .env et remplir les valeurs.
# Sur le serveur Hetzner, ce fichier vit dans /opt/scripts/youtube-shorts-bot/.env

# ─── OAuth Google (créé dans Google Cloud Console > Identifiants) ──────
# Type : "ID client OAuth" > "Application de bureau"
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Refresh token obtenu en lançant `npm run auth` une seule fois.
# Couvre à la fois l'upload YouTube et l'accès Drive (un seul consentement).
GOOGLE_REFRESH_TOKEN=

# ─── Dossiers Google Drive ────────────────────────────────────────────
# ID du dossier surveillé (« À publier »). Le bot ne touche QUE ce dossier.
# L'ID se trouve dans l'URL du dossier : drive.google.com/drive/folders/<ID>
DRIVE_SOURCE_FOLDER_ID=

# ID du dossier « Publié » où les vidéos sont déplacées après publication.
DRIVE_PUBLISHED_FOLDER_ID=

# ─── Comportement ─────────────────────────────────────────────────────
# Nombre maximum de vidéos publiées par exécution (garde-fou + quota YouTube).
# Quota par défaut : ~6 uploads/jour. Garder MAX_PER_RUN bas.
MAX_PER_RUN=5

# Statut de publication : public | unlisted | private
PRIVACY_STATUS=public

# Description appliquée à chaque Short. #Shorts aide YouTube à les classer.
# (Le titre, lui, est toujours le nom du fichier sans extension.)
DEFAULT_DESCRIPTION=#Shorts

# Catégorie YouTube (22 = People & Blogs, 25 = News & Politics, 27 = Education).
YOUTUBE_CATEGORY_ID=25

# Langue par défaut des métadonnées.
DEFAULT_LANGUAGE=fr
